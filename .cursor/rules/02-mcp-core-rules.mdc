# MCP & AI Service Integration Patterns

## Service Architecture

### Core Service Structure
```dart
abstract class BaseAIService {
  Future<AIResponse> generate(AIRequest request);
  void dispose();
}

class AIServiceConfig {
  final String apiKey;
  final String baseUrl;
  final Duration timeout;
  final int maxRetries;
  
  const AIServiceConfig({
    required this.apiKey,
    required this.baseUrl,
    this.timeout = const Duration(seconds: 30),
    this.maxRetries = 3,
  });
}
```

### Error Handling Patterns
```dart
enum AIErrorCode {
  networkError,
  timeout,
  invalidResponse,
  rateLimit,
  authenticationError,
  serverError,
}

class AIServiceException implements Exception {
  final AIErrorCode code;
  final String message;
  final dynamic data;
  final bool retriable;
  
  const AIServiceException({
    required this.code,
    required this.message,
    this.data,
    this.retriable = false,
  });
  
  bool get shouldRetry => retriable || _isTransientError(code);
  
  static bool _isTransientError(AIErrorCode code) {
    return [AIErrorCode.networkError, AIErrorCode.timeout, AIErrorCode.rateLimit]
        .contains(code);
  }
}
```

### Retry Implementation
```dart
class RetryHandler {
  Future<T> withRetry<T>(
    Future<T> Function() operation, {
    int maxAttempts = 3,
    Duration initialDelay = const Duration(seconds: 1),
  }) async {
    int attempts = 0;
    Duration delay = initialDelay;
    
    while (true) {
      try {
        return await operation();
      } on AIServiceException catch (e) {
        attempts++;
        if (!e.shouldRetry || attempts >= maxAttempts) rethrow;
        await Future.delayed(delay);
        delay *= 2; // Exponential backoff
      }
    }
  }
}
```

## AI Service Implementations

### Nutrition AI Service
```dart
class NutritionAIService extends BaseAIService {
  final GeminiClient _geminiClient;
  final MealSuggestionService _mealService;
  
  Future<NutritionResult> analyzeMeal(String description) async {
    final request = AIRequest(
      prompt: _buildNutritionPrompt(description),
      temperature: 0.3,
    );
    
    final response = await _retryHandler.withRetry(
      () => _geminiClient.generate(request),
    );
    
    return NutritionResult.fromJson(response.data);
  }
  
  Future<List<MealSuggestion>> suggestMeals({
    required double targetCalories,
    required List<String> preferences,
  }) async {
    final request = AIRequest(
      prompt: _buildSuggestionPrompt(targetCalories, preferences),
      temperature: 0.7,
    );
    
    return _mealService.parseSuggestions(
      await _geminiClient.generate(request),
    );
  }
}
```

### Food Recognition Service
```dart
class FoodRecognitionService {
  final ImageClassifier _classifier;
  final NutritionAIService _nutritionAI;
  final FoodRecognitionPersistence _persistence;
  
  Future<FoodRecognitionResult> recognizeFood(String imagePath) async {
    // 1. Check cache first
    final cached = await _persistence.getCached(imagePath);
    if (cached != null) return cached;
    
    // 2. Classify image
    final classification = await _classifier.classify(imagePath);
    
    // 3. Enhance with AI
    final enhanced = await _nutritionAI.analyzeMeal(classification.label);
    
    // 4. Cache result
    final result = FoodRecognitionResult(
      foods: enhanced.foods,
      confidence: classification.confidence,
      timestamp: DateTime.now(),
    );
    
    await _persistence.save(imagePath, result);
    return result;
  }
}
```

