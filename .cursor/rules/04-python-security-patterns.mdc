### Environment Security
```python
# Good: Secure environment variable handling
class SecureConfig:
    REQUIRED_SECRETS = ["DATABASE_URL", "SECRET_KEY", "API_KEY"]
    
    def __init__(self):
        self._validate_environment()
    
    def _validate_environment(self) -> None:
        missing = [s for s in self.REQUIRED_SECRETS if not os.getenv(s)]
        if missing:
            raise ConfigurationError(f"Missing required secrets: {missing}")
    
    @property
    def database_url(self) -> str:
        url = os.getenv("DATABASE_URL")
        return self._mask_sensitive_in_url(url)
    
    def _mask_sensitive_in_url(self, url: str) -> str:
        # Mask password in connection strings
        parsed = urlparse(url)
        if parsed.password:
            return url.replace(parsed.password, "***")
        return url
```

