# Security & Clean Code Patterns

## Security-First Development

### Input Validation
```python
# Good: Comprehensive input validation
class SecureInputValidator:
    @staticmethod
    def validate_food_input(food_name: str) -> ValidationResult:
        if not food_name or len(food_name) > 500:
            return ValidationResult.valid(False, "Invalid food name length")
        
        # Sanitize input
        sanitized = sanitize_string(food_name)
        
        # Check for injection patterns
        if contains_malicious_patterns(sanitized):
            return ValidationResult.valid(False, "Potentially dangerous input")
        
        return ValidationResult.valid(True, sanitized=sanitized)
    
    @staticmethod
    def validate_calorie_input(calories: float) -> ValidationResult:
        if not isinstance(calories, (int, float)):
            return ValidationResult.valid(False, "Invalid type")
        if calories < 0 or calories > 10000:
            return ValidationResult.valid(False, "Calorie value out of range")
        return ValidationResult.valid(True)
```

### Authentication & Authorization
```python
# Good: Secure authentication pattern
class SecureAuthService:
    def __init__(self, db_pool: ConnectionPool):
        self.db_pool = db_pool
        self._rate_limiter = RateLimiter(max_attempts=5, window=300)
    
    async def authenticate(self, credentials: Credentials) -> AuthResult:
        # Rate limiting
        if not await self._rate_limiter.check(credentials.username):
            return AuthResult.failed("Too many attempts")
        
        # Secure password verification
        user = await self._verify_credentials(credentials)
        if not user:
            return AuthResult.failed("Invalid credentials")
        
        # Generate secure token
        token = self._generate_jwt(user)
        return AuthResult.success(token=token, user_id=user.id)
    
    def _generate_jwt(self, user: User) -> str:
        payload = {
            "sub": user.id,
            "exp": datetime.utcnow() + timedelta(hours=1),
            "iat": datetime.utcnow(),
            "scope": user.permissions
        }
        return jwt.encode(payload, SECRET_KEY, algorithm="HS256")
```

### Data Encryption
```python
# Good: Encrypted data handling
class EncryptedDataStore:
    def __init__(self, encryption_key: bytes):
        self.cipher = AESGCM(encryption_key)
    
    def encrypt(self, data: bytes) -> EncryptedData:
        nonce = os.urandom(12)
        ciphertext = self.cipher.encrypt(nonce, data, None)
        return EncryptedData(nonce=nonce, ciphertext=ciphertext)
    
    def decrypt(self, encrypted: EncryptedData) -> bytes:
        return self.cipher.decrypt(encrypted.nonce, encrypted.ciphertext, None)
    
    async def store_health_data(self, user_id: str, data: HealthData) -> None:
        encrypted = self.encrypt(json.dumps(data.to_dict()).encode())
        await self.db.execute(
            "INSERT INTO health_data (user_id, nonce, data) VALUES (?, ?, ?)",
            user_id, encrypted.nonce, encrypted.ciphertext
        )
```

### Secure API Design
```python
# Good: Secure API endpoint pattern
class SecureAPIService:
    def __init__(self):
        self.validator = SecureInputValidator()
        self.auth = SecureAuthService()
    
    @require_auth
    @validate_input
    async def log_meal(self, request: MealRequest) -> MealResponse:
        # Validate input
        validation = self.validator.validate_food_input(request.food_name)
        if not validation.is_valid:
            raise ValidationError(validation.message)
        
        # Process with logging
        meal = await self._create_meal(request, request.user_id)
        
        # Audit log
        await self._audit_log(request.user_id, "meal_logged", {
            "food": request.food_name,
            "calories": request.calories
        })
        
        return MealResponse(success=True, meal_id=meal.id)
    
    async def _audit_log(self, user_id: str, action: str, details: dict) -> None:
        await self.audit_db.execute(
            "INSERT INTO audit_logs (user_id, action, details, timestamp) VALUES (?, ?, ?, ?)",
            user_id, action, json.dumps(details), datetime.utcnow()
        )
```

## Error Handling & Logging

### Secure Error Responses
```python
# Good: Don't leak sensitive info in errors
class SecureErrorHandler:
    # Public safe error messages
    SAFE_MESSAGES = {
        "auth_failed": "Invalid credentials",
        "rate_limited": "Too many requests",
        "validation_error": "Invalid input",
        "server_error": "An error occurred",
    }
    
    @classmethod
    def handle_error(cls, error: Exception, include_debug: bool = False) -> ErrorResponse:
        error_id = generate_error_id()
        
        # Always log full details internally
        logger.error(f"[{error_id}] {type(error).__name__}: {error}", exc_info=True)
        
        # Return safe message to client
        safe_message = cls.SAFE_MESSAGES.get(type(error).__name__, cls.SAFE_MESSAGES["server_error"])
        
        response = ErrorResponse(
            error_id=error_id,
            message=safe_message,
        )
        
        if include_debug:
            response.debug_info = {
                "type": type(error).__name__,
                "timestamp": datetime.utcnow().isoformat()
            }
        
        return response
```

### Security Logging
```python
# Good: Comprehensive security logging
class SecurityLogger:
    SUSPICIOUS_PATTERNS = [
        "sql_injection",
        "xss_attempt",
        "brute_force",
        "unauthorized_access",
        "data_exfiltration",
    ]
    
    async def log_security_event(
        self,
        event_type: str,
        user_id: Optional[str],
        details: dict,
        severity: str = "info"
    ) -> None:
        event = SecurityEvent(
            timestamp=datetime.utcnow(),
            type=event_type,
            user_id=user_id,
            details=details,
            severity=severity,
            suspicious=event_type in self.SUSPICIOUS_PATTERNS
        )
        
        await self.security_db.insert("security_logs", event.to_dict())
        
        if event.suspicious:
            await self._trigger_security_alert(event)
```

